              "    pm.expect(record._id).to.eql(pm.collectionVariables.get('createdRecordId'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "08 - Update created record",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"location\": \"{{testLocation}}\",\n  \"period\": 2026,\n  \"totalEmissionsMt\": 15,\n  \"emissionsIntensity\": null,\n  \"emissionsPerCapita\": 3.5,\n  \"annualVariation\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/carbon-emission-records/{{createdRecordId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carbon-emission-records",
            "{{createdRecordId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Record was updated', function () {",
              "    const json = pm.response.json();",
              "    const record = json.record || json;",
              "    pm.expect(record.totalEmissionsMt).to.eql(15);",
              "    pm.expect(record.emissionsIntensity).to.eql(null);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
