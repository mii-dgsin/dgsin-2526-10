{
  "info": {
    "name": "DGSIN-2526-10 API Tests",
    "description": "Postman collection for testing the DGSIN-2526-10 backend deployed on Google App Engine. It covers the carbon emission records API, integration endpoints, expected errors, and basic response validations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://dgsin-2526-10-mjcadenas.ew.r.appspot.com",
      "type": "string"
    },
    {
      "key": "createdRecordId",
      "value": "",
      "type": "string"
    },
    {
      "key": "testLocation",
      "value": "",
      "type": "string"
    },
    {
      "key": "testPeriod",
      "value": "2026",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has status ok', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Get all carbon emission records",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/carbon-emission-records?limit=10&offset=0",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carbon-emission-records"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains records array and pagination fields', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('records');",
              "    pm.expect(json.records).to.be.an('array');",
              "    pm.expect(json).to.have.property('total');",
              "    pm.expect(json).to.have.property('limit');",
              "    pm.expect(json).to.have.property('offset');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Get records filtered by location and year range",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/carbon-emission-records?location=Spain&fromPeriod=2020&toPeriod=2023&limit=50&offset=0",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carbon-emission-records"
          ],
          "query": [
            {
              "key": "location",
              "value": "Spain"
            },
            {
              "key": "fromPeriod",
              "value": "2020"
            },
            {
              "key": "toPeriod",
              "value": "2023"
            },
            {
              "key": "limit",
              "value": "50"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Records array is returned', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.records).to.be.an('array');",
              "});",
              "",
              "pm.test('Returned records match requested year range when present', function () {",
              "    const json = pm.response.json();",
              "    json.records.forEach((record) => {",
              "        pm.expect(record.period).to.be.at.least(2020);",
              "        pm.expect(record.period).to.be.at.most(2023);",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 - Get available local locations",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/carbon-emission-records/locations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carbon-emission-records",
            "locations"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Locations are returned as an array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('locations');",
              "    pm.expect(json.locations).to.be.an('array');",
              "    pm.expect(json.total).to.eql(json.locations.length);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Create test carbon emission record",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const uniqueLocation = 'Postman Test Country ' + Date.now();",
              "pm.collectionVariables.set('testLocation', uniqueLocation);",
              "pm.collectionVariables.set('testPeriod', '2026');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Created record has an id and expected values', function () {",
              "    const json = pm.response.json();",
              "    const record = json.record || json;",
              "    pm.expect(record).to.have.property('_id');",
              "    pm.expect(record.location).to.eql(pm.collectionVariables.get('testLocation'));",
              "    pm.expect(record.period).to.eql(Number(pm.collectionVariables.get('testPeriod')));",
              "    pm.collectionVariables.set('createdRecordId', record._id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"location\": \"{{testLocation}}\",\n  \"period\": 2026,\n  \"totalEmissionsMt\": 10,\n  \"emissionsIntensity\": 1.5,\n  \"emissionsPerCapita\": 2.5,\n  \"annualVariation\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/carbon-emission-records",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carbon-emission-records"
          ]
        }
      }
    },
    {
      "name": "06 - Create duplicate record should fail",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"location\": \"{{testLocation}}\",\n  \"period\": 2026,\n  \"totalEmissionsMt\": 20,\n  \"emissionsIntensity\": 2,\n  \"emissionsPerCapita\": 3,\n  \"annualVariation\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/carbon-emission-records",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carbon-emission-records"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 409 Conflict', function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "",
              "pm.test('Duplicate error message is returned', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.message).to.include('already exists');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07 - Get created record by id",
      "request": {
        "method": "GET",
        "header": [],
