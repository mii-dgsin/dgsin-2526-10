    {
      "key": "baseUrl",
      "value": "https://dgsin-2526-10-mjcadenas.ew.r.appspot.com",
      "type": "string"
    },
    {
      "key": "createdRecordId",
      "value": "",
      "type": "string"
    },
    {
      "key": "testLocation",
      "value": "",
      "type": "string"
    },
    {
      "key": "testPeriod",
      "value": "2026",
      "type": "string"
    },
    {
      "key": "postmanDocsUrl",
