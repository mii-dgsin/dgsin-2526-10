  ],
  "item": [
    {
      "name": "01 - Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has status ok and service name', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.status).to.eql('ok');",
              "    pm.expect(json.service).to.eql('carbon-emission-records-api');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Get all carbon emission records",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/carbon-emission-records?limit=10&offset=0",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carbon-emission-records"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "",
              "pm.test('Response contains records array and pagination fields', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('records');",
              "    pm.expect(json.records).to.be.an('array');",
              "    pm.expect(json).to.have.property('total');",
              "    pm.expect(json).to.have.property('limit');",
              "    pm.expect(json).to.have.property('offset');",
              "    pm.expect(json.limit).to.eql(10);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Get records filtered by location and year range",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/carbon-emission-records?location=Spain&fromPeriod=2020&toPeriod=2023&limit=50&offset=0",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "carbon-emission-records"
          ],
          "query": [
            {
              "key": "location",
              "value": "Spain"
            },
            {
              "key": "fromPeriod",
              "value": "2020"
            },
            {
              "key": "toPeriod",
              "value": "2023"
            },
            {
              "key": "limit",
              "value": "50"
            },
            {
              "key": "offset",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "",
              "pm.test('Returned records are inside requested year range', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.records).to.be.an('array');",
              "    json.records.forEach((record) => {",
              "        pm.expect(record.period).to.be.at.least(2020);",
              "        pm.expect(record.period).to.be.at.most(2023);",
              "        pm.expect(record.location.toLowerCase()).to.include('spain');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
