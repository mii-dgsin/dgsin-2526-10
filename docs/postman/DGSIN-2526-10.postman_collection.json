{
  "info": {
    "name": "DGSIN-2526-10 API Tests",
    "description": "Postman collection for testing the DGSIN-2526-10 backend deployed on Google App Engine. It covers the carbon emission records API, required REST operations, expected errors, 405 method-not-allowed checks, Postman documentation redirect and integration endpoints.",
