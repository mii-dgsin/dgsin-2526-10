    {
      "name": "05 - Create test carbon emission record",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const uniqueLocation = 'Postman Test Country ' + Date.now();",
              "pm.collectionVariables.set('testLocation', uniqueLocation);",
              "pm.collectionVariables.set('testPeriod', '2026');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
              "",
              "pm.test('Created record has an id and expected values', function () {",
              "    const record = pm.response.json();",
              "    pm.expect(record).to.have.property('_id');",
              "    pm.expect(record.location).to.eql(pm.collectionVariables.get('testLocation'));",
              "    pm.expect(record.period).to.eql(Number(pm.collectionVariables.get('testPeriod')));",
              "    pm.collectionVariables.set('createdRecordId', record._id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"location\": \"{{testLocation}}\",\n  \"period\": 2026,\n  \"totalEmissionsMt\": 10,\n  \"emissionsIntensity\": 1.5,\n  \"emissionsPerCapita\": 2.5,\n  \"annualVariation\": null\n}"
        },
